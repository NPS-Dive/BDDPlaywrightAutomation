{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],

    "module": "Node16",
    "moduleResolution": "Node16",

    "strict": true,
    "skipLibCheck": true,

    "rootDir": ".",
    "outDir": "./dist",

    "types": ["node"],
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts", "features/**/*.feature"],
  "exclude": ["node_modules", "dist"]
}
